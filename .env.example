# Environment variables for fending-gpt
# Copy to .env.local and fill in actual values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Claude AI API Key (https://console.anthropic.com/)
CLAUDE_API_KEY=sk-ant-api03-your_claude_api_key

# reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Postmark Email API (https://postmarkapp.com/)
POSTMARK_SERVER_TOKEN=your_postmark_server_token

# NextAuth.js / Session Management
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Admin Configuration
ADMIN_EMAIL=admin@yourdomain.com

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI API Key for embeddings (https://platform.openai.com/)
OPENAI_API_KEY=sk-your_openai_api_key
